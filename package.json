{
    "name": "presentation-upload-api",
    "version": "1.0.0",
    "description": "",
    "main": "dist/src/server.js",
    "scripts": {
        "test": "vitest run",
        "build": "tsc -p tsconfig.json && npm run build:frontend",
        "build:frontend": "vite build --config src/frontend/vite.config.ts",
        "dev": "concurrently -k -n backend,frontend -c green,blue \"npm run dev:backend\" \"npm run dev:frontend\"",
        "dev:backend": "npm run db:sync && tsx watch src/server.ts",
        "dev:frontend": "vite --config src/frontend/vite.config.ts",
        "start": "node dist/src/server.js",
        "db:sync": "prisma db push --skip-generate",
        "prisma:generate": "prisma generate",
        "genpass": "node scripts/genpass.mjs",
        "prettier:check": "prettier --check .",
        "prettier:fix": "prettier --write ."
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "dependencies": {
        "@fastify/cookie": "^11.0.2",
        "@fastify/cors": "^11.2.0",
        "@fastify/helmet": "^13.0.2",
        "@fastify/multipart": "^9.4.0",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/static": "^9.0.0",
        "@hookform/resolvers": "^5.2.2",
        "@prisma/client": "^6.19.2",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@tanstack/react-query": "^5.90.21",
        "argon2": "^0.44.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "fastify": "^5.8.3",
        "jose": "^6.1.3",
        "lucide-react": "^0.577.0",
        "mime-types": "^3.0.2",
        "motion": "^12.35.2",
        "prettier": "^3.8.1",
        "prisma": "^6.19.2",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-hook-form": "^7.71.2",
