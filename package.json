        "@types/react-dom": "^19.2.3",
        "@types/supertest": "^7.2.0",
        "@types/unzipper": "^0.10.11",
        "@vitejs/plugin-react": "^5.1.4",
        "jszip": "^3.10.1",
        "supertest": "^7.2.2",
        "tailwindcss": "^4.2.1",
        "concurrently": "^9.2.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
