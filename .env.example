NODE_ENV=development
HOST=127.0.0.1
PORT=3000

DATABASE_URL=file:./dev.db

# Absolute or relative path; presentation files are stored under this directory.
LOCAL_ASSETS_ROOT=./storage/presentations

# Set true when the app runs behind a trusted reverse proxy (client IP / forwarded headers).
TRUST_PROXY=false

JWT_SECRET=replace-with-at-least-32-characters
UPLOAD_PRINCIPALS=[{"username":"deploy-bot","passwordHash":"$argon2id$replace-with-a-real-hash"}]
UPLOAD_MAX_BYTES=52428800
UPLOAD_MAX_FILES_IN_ZIP=500
UPLOAD_MAX_CONCURRENT=2
UNLOCK_TOKEN_TTL_SECONDS=3600
